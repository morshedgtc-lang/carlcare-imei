            "text": "{\"data\": {\"oid\": \"656832070E0CA00AB5558AFB\", \"ctime\": 1701327367028, \"utime\": 1701327367028, \"owner_id\": \"6565566AD0B077C91940FF4C\", \"active\": true, \"name\": \"H5_OfficialWebsite_Global\", \"config\": {\"website\": {\"name\": \"H5_OfficialWebsite_Global\", \"title\": \"Carlcare Service\", \"avatar\": \"\"}, \"widget\": {\"color\": \"#0076E0\", \"title\": \"widget title\", \"avatar\": \"\", \"position\": \"right\", \"title_color\": \"#0076E0\", \"is_show_title\": false}, \"message_type\": [\"text\"], \"message_style\": {\"system_font_color\": \"#0076E0\", \"customer_font_color\": \"#0076E0\", \"system_background_color\": \"#0076E0\", \"customer_background_color\": \"#0076E0\"}, \"button_disable\": [\"\"]}, \"webhook\": \"https://aicc-hk.transsion.com/swai/cc-desk/third-party-webhook-api/webhook/website/018c1f036b22fbd9099fdafceddf05d2\", \"weburl\": \"https://aicc-hk.transsion.com/swai/cc-desk/websdk-ui/index.html?token=656832070E0CA00AB5558AFB\", \"webscript\": \"\\n<script>\\n\\n(function(d, t) {\\n            var BASE_URL = \\\"https://aicc-hk.transsion.com/swai/cc-desk/websdk-ui\\\";\\n            var HOST = \\\"https://aicc-hk.transsion.com\\\"\\n            var TOKEN = \\\"656832070E0CA00AB5558AFB\\\";\\n            var g = d.createElement(t),\\n                s = d.getElementsByTagName(t)[0];\\n            g.src = BASE_URL + \\\"/js/sdk.js\\\";\\n            g.defer = true;\\n            g.async = true;\\n            s.parentNode.insertBefore(g, s);\\n            g.onload = function() {\\n                window.addEventListener('message', function (event) {\\n                        const iframe = document.getElementById('chat-form-container');\\n                        const OpenContent = document.getElementById('bubble-container');\\n                        if (iframe) {\\n                          iframe.style.display = 'none'\\n                        }\\n                        if (OpenContent) {\\n                          OpenContent.style.display = 'block'\\n                        }\\n                      });\\n                window.WebsiteSdk.run({\\n                    token: TOKEN,\\n                    baseUrl: BASE_URL,\\n                    host: HOST\\n                })\\n            }\\n        })(document, \\\"script\\\");\\n\\n</script>\\n\\n\", \"language_code\": \"all\", \"country_code\": \"ALL\", \"pre_replys\": {\"greeting\": {\"line1\": \"Hello, I'm Carlcare AIbot!\", \"line2\": \"Nice to meet you!\", \"line3\": \"Carlcare AIbot can answer all your questions \", \"line4\": \"about TECNO/Infinix/itel/Oraimo/Syinix. \", \"line5\": \"Now, Please tell me your questions\"}}}, \"code\": 0, \"error\": 0, \"message\": \"Ok\", \"timestamp\": 1781528670}"
